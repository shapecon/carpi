{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2024",
    "module": "es2022",
    "lib": ["es2024", "dom"],
    "types": ["@webgpu/types", "jest", "node"],
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": "./src",
    "paths": {
      "@audio": ["main/audio/index.ts"],
      "@audio/*": ["main/audio/*"],
      "@renderer/*": ["renderer/src/*"],
      "@projection/messages": ["main/services/projection/messages/index.ts"],
      "@projection/messages/*": ["main/services/projection/messages/*"],
      "@main/*": ["main/*"],
      "@shared/*": ["main/shared/*"],
      "@worker/*": ["renderer/src/components/worker/*"],
      "@store/*": ["renderer/src/store/*"],
      "@utils/*": ["renderer/src/utils/*"],
      "@types/*": ["renderer/src/types/*"]
    }
  },
  "include": ["src/**/*", "src/types"]
}
