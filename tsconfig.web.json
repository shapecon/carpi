{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/types/**/*",
    "jest.setup.ts",
    "jest.web.setup.ts"
  ],
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "target": "es2024",
    "module": "es2022",
    "lib": ["dom", "dom.iterable", "es2024", "webworker"],
    "types": ["jest", "@testing-library/jest-dom", "@webgpu/types", "w3c-web-usb", "vite/client"],
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "baseUrl": "./src",
    "paths": {
      "@renderer/*": ["renderer/src/*"],
      "@projection/messages": ["main/services/projection/messages/index.ts"],
      "@projection/messages/*": ["main/services/projection/messages/*"],
      "@main/*": ["main/*"],
      "@shared/*": ["main/shared/*"],
      "@worker/*": ["renderer/src/components/worker/*"],
      "@store/*": ["renderer/src/store/*"],
      "@utils/*": ["renderer/src/utils/*"],
      "@types/*": ["renderer/src/types/*"]
    }
  }
}
